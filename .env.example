# Copy this file to .env.local for local development.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Never commit .env.local or any file containing real secrets.

# ── Currently unused (app runs on generated fake data) ───────────────────────
# Uncomment and fill in when connecting to a real API:

# VITE_API_BASE_URL=https://your-analytics-api.example.com
# VITE_API_KEY=your_api_key_here

# ── Optional feature flags ─────────────────────────────────────────────────────
# VITE_ENABLE_REAL_API=false
